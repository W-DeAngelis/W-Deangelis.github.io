---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="hero-label">SERIES</div>
        <h1>Building an AEGIS AI System<br/>from the Ground Up</h1>
        <p class="hero-sub">
          A technical series on radar track anomaly detection — from Kalman filter
          baselines to production ML pipelines. Written by a former Navy AEGIS
          technician learning to build the systems he once operated.
        </p>
        <div class="hero-tags">
          <span class="tag">Radar Tracking</span>
          <span class="tag">Kalman Filter</span>
          <span class="tag">PyTorch</span>
          <span class="tag">MLOps</span>
          <span class="tag">Defense AI</span>
        </div>
      </section>

      <section class="posts-section">
        <h2 class="section-heading">Posts</h2>
        {posts.map((post) => (
          <a href={`/blog/${post.id}/`} class="post-card">
            <div class="post-meta">
              <FormattedDate date={post.data.pubDate} />
              {post.data.tags?.map((tag: string) => (
                <span class="post-tag">{tag}</span>
              ))}
            </div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
          </a>
        ))}
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .hero {
    padding: 2.5em 0 2em 0;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2.5em;
  }
  .hero-label {
    font-size: 0.75em;
    letter-spacing: 0.12em;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 0.75em;
    font-weight: 700;
  }
  .hero h1 {
    font-size: 2.2em;
    line-height: 1.15;
    margin-bottom: 0.6em;
    color: var(--text-heading);
  }
  .hero-sub {
    color: var(--text-muted);
    font-size: 1.05em;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 1.25em;
  }
  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5em;
  }
  .section-heading {
    font-size: 0.8em;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.25em;
    font-weight: 600;
  }
  .posts-section { margin-top: 1em; }
</style>
