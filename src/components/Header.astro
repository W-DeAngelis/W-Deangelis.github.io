---
import { SITE_TITLE, GITHUB_URL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---
<header>
  <nav>
    <div class="site-title">
      <a href="/">{SITE_TITLE}</a>
      <span class="title-sub">ML / Radar / Defense AI</span>
    </div>
    <div class="internal-links">
      <HeaderLink href="/">Posts</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>
    <div class="social-links">
      <a href={GITHUB_URL} target="_blank" title="GitHub">
        <span class="sr-only">GitHub</span>
        <svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
          <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  header {
    margin: 0;
    padding: 0 1.5em;
    background: #111827;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 760px;
    margin: 0 auto;
    height: 56px;
  }
  .site-title {
    display: flex;
    flex-direction: column;
    gap: 0;
    line-height: 1.1;
  }
  .site-title a {
    font-weight: 700;
    font-size: 1em;
    color: var(--text-heading);
    text-decoration: none;
  }
  .site-title a:hover { color: var(--accent); text-decoration: none; }
  .title-sub {
    font-size: 0.65em;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }
  .internal-links {
    display: flex;
    gap: 0.5em;
  }
  nav a {
    padding: 0.4em 0.75em;
    color: var(--text-muted);
    border-bottom: 2px solid transparent;
    text-decoration: none;
    font-size: 0.95em;
    transition: color 0.15s ease;
  }
  nav a:hover, nav a.active {
    color: var(--accent);
    text-decoration: none;
    border-bottom-color: var(--accent);
  }
  .social-links a {
    color: var(--text-muted);
    display: flex;
    align-items: center;
    transition: color 0.15s ease;
  }
  .social-links a:hover { color: var(--accent); }
  @media (max-width: 720px) {
    .title-sub { display: none; }
  }
</style>
